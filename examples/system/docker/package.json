{
  "name": "bitcoin-crawler-docker-example",
  "private": true,
  "version": "0.3.0",
  "description": "This is an example app for development",
  "type": "commonjs",
  "scripts": {
    "clear": "yarn clear cache && clear:node_modules",
    "clear:node_modules": "rimraf node_module",
    "start": "node -r ts-node/register/transpile-only src/main.ts",
    "docker:build": "docker build -t bitcoin-crawler-docker-example .",
    "docker:run": "docker run --rm --add-host=host.docker.internal:host-gateway --name bitcoin-crawler-docker-example --env-file .env -p 3000:3000 bitcoin-crawler-docker-example",
    "docker:run:detached": "docker run -d --add-host=host.docker.internal:host-gateway --name bitcoin-crawler-docker-example --env-file .env -p 3000:3000 bitcoin-crawler-docker-example",
    "docker:stop": "docker stop bitcoin-crawler-docker-example",
    "docker:logs": "docker logs -f bitcoin-crawler-docker-example"
  },
  "dependencies": {
    "@easylayer/bitcoin-crawler": "0.3.0",
    "@easylayer/common": "1.2.0",
    "@easylayer/transport-sdk": "1.3.0",
    "express": "5.1.0",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "@types/express": "5",
    "@types/node": "20.10.4",
    "rimraf": "5.0.5",
    "ts-node": "10.9.2",
    "typescript": "5.3.3"
  },
  "author": {
    "name": "developer"
  },
  "easylayer": {
    "uuid": "a2903462-4cbe-4a2f-9852-bf89714b5b13"
  },
  "engines": {
    "node": ">=20.0.0 <=22.x.x"
  },
  "license": ""
}
