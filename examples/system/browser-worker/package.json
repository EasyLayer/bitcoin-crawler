{
  "name": "bitcoin-crawler-browser-worker-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:worker": "vite build --config vite.worker.config.ts",
    "build:app": "vite build --config vite.config.ts",
    "build": "yarn build:worker && yarn build:app",
    "start": "yarn build && vite preview --config vite.config.ts"
  },
  "dependencies": {
    "@easylayer/bitcoin": "1.2.0",
    "@easylayer/bitcoin-crawler": "0.2.1",
    "@easylayer/common": "1.2.0",
    "@easylayer/transport-sdk": "1.3.0",
    "reflect-metadata": "0.1.14"
  },
  "devDependencies": {
    "@types/node": "20.10.4",
    "typescript": "5.3.3",
    "vite": "5.0.0"
  }
}
