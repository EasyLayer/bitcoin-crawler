# Electron main process — full Node bootstrap (SQLite, all providers supported)
# Renderer queries main via ipcRenderer.invoke — no outbox transport needed.

NODE_ENV=production
NETWORK_TYPE=testnet
NETWORK_PROVIDER_TYPE=rpc
START_BLOCK_HEIGHT=0
TRANSPORT_OUTBOX_ENABLE=1
TRANSPORT_OUTBOX_KIND=electron-ipc-main
PROVIDER_NETWORK_RPC_URLS= #http://btc:pass@127.0.0.1:18332
