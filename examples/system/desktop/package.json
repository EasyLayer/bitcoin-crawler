{
  "name": "bitcoin-crawler-desktop-example",
  "version": "0.3.1",
  "private": true,
  "main": "dist/electron/main.js",
  "build": {
    "appId": "com.easylayer.bitcoin-crawler",
    "productName": "Bitcoin Crawler",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json",
      ".env",
      "node_modules/**/*",
      {
        "from": "../../../node_modules",
        "to": "node_modules",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "scripts": {
    "build:main": "node esbuild.config.mjs",
    "build:renderer": "vite build",
    "build": "yarn build:main && yarn build:renderer",
    "postinstall": "electron-rebuild -f -w sqlite3,better-sqlite3",
    "start": "yarn build && electron .",
    "app": "yarn build && electron-builder --mac --linux",
    "app:mac": "yarn build && electron-builder --mac",
    "app:linux": "yarn build && electron-builder --linux"
  },
  "dependencies": {
    "@easylayer/bitcoin": "1.3.1",
    "@easylayer/bitcoin-crawler": "0.3.1",
    "@easylayer/common": "1.3.1",
    "@easylayer/transport-sdk": "1.3.0",
    "dotenv": "16.3.1",
    "reflect-metadata": "0.1.14"
  },
  "devDependencies": {
    "@electron/rebuild": "4.0.3",
    "@types/node": "20.10.4",
    "concurrently": "8.0.0",
    "electron": "28.0.0",
    "electron-builder": "26.8.1",
    "esbuild": "0.19.0",
    "typescript": "5.3.3",
    "vite": "5.0.0",
    "wait-on": "7.2.0"
  }
}
